SECRET_KEY=replace-with-a-secure-random-value
SESSION_COOKIE_SECURE=false

# Optional locally. If omitted, StudExEl uses database/studexel.db.
# DATABASE_URL=sqlite:///database/studexel.db

# Production PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://username:password@host/database_name

# Optional upload location override.
# ITEM_IMAGE_UPLOAD_FOLDER=backend/static/uploads/items
